# ── AI Provider Keys ─────────────────────────────────────────────────────────
# At least one key is required; the backend falls back to a local simulation
# for any provider whose key is absent.

# Gemini (Google) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"

# ── Application ───────────────────────────────────────────────────────────────
# APP_URL: The URL where this applet is hosted (injected automatically in AI Studio).
APP_URL="MY_APP_URL"

# PORT: HTTP port for the Express server (default: 3000)
# PORT=3000

# ── Deployment ────────────────────────────────────────────────────────────────
# CORS_ORIGIN: Restrict cross-origin access to this frontend URL.
# Use * to allow all origins (development only).
# CORS_ORIGIN=https://your-app.vercel.app

# VITE_API_URL: Set on Vercel (or locally) to point the frontend at the
# deployed backend. Leave blank when frontend and backend share an origin.
# VITE_API_URL=https://your-backend.onrender.com
